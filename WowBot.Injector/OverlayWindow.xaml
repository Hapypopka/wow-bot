<Window x:Class="WowBot.Injector.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WowBot" Width="240" Height="200"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        ShowInTaskbar="False" ResizeMode="NoResize"
        Left="20" Top="300">

    <Border Background="#DD0d1117" CornerRadius="12" BorderBrush="#30363d" BorderThickness="1"
            MouseLeftButtonDown="Header_MouseLeftButtonDown">

        <StackPanel Margin="14">
            <!-- Header -->
            <DockPanel Margin="0,0,0,10">
                <TextBlock Text="WowBot" FontSize="16" FontWeight="Bold" Foreground="#e94560"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtStatus" Text="" FontSize="10" Foreground="#555"
                           VerticalAlignment="Center" HorizontalAlignment="Right" DockPanel.Dock="Right"/>
            </DockPanel>

            <!-- Rotation Toggle -->
            <Border Background="#161b22" CornerRadius="8" Padding="10,8" Margin="0,0,0,6"
                    MouseLeftButtonDown="BtnRotation_Click" Cursor="Hand">
                <DockPanel>
                    <Border x:Name="RotationDot" Width="10" Height="10" CornerRadius="5"
                            Background="#e94560" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Rotation" Foreground="#c9d1d9" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtRotationState" Text="OFF" Foreground="#e94560"
                               FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"
                               DockPanel.Dock="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Follow Toggle -->
            <Border Background="#161b22" CornerRadius="8" Padding="10,8" Margin="0,0,0,6"
                    MouseLeftButtonDown="BtnFollow_Click" Cursor="Hand">
                <DockPanel>
                    <Border x:Name="FollowDot" Width="10" Height="10" CornerRadius="5"
                            Background="#e94560" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Follow" Foreground="#c9d1d9" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtFollowState" Text="OFF" Foreground="#e94560"
                               FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"
                               DockPanel.Dock="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Info line -->
            <TextBlock x:Name="TxtInfo" Text="HP: - | Target: -" Foreground="#484f58"
                       FontSize="10" FontFamily="Consolas" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</Window>
