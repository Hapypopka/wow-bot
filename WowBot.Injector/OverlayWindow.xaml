<Window x:Class="WowBot.Injector.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WowBot" Width="400" Height="350"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        ShowInTaskbar="False" ResizeMode="NoResize"
        Left="20" Top="300">

    <Window.Resources>
        <SolidColorBrush x:Key="BgDark" Color="#E5111319"/>
        <SolidColorBrush x:Key="BgSection" Color="#1e2028"/>
        <SolidColorBrush x:Key="BgItem" Color="#16181e"/>
        <SolidColorBrush x:Key="Gold" Color="#c8aa6e"/>
        <SolidColorBrush x:Key="TextDim" Color="#5a5d65"/>
        <SolidColorBrush x:Key="TextLight" Color="#8b8d93"/>

        <!-- Menu item style -->
        <Style x:Key="MenuItem" TargetType="Border">
            <Setter Property="Background" Value="#1e2028"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#282b34"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Toggle button style -->
        <Style x:Key="ToggleBtn" TargetType="ToggleButton">
            <Setter Property="Background" Value="#252830"/>
            <Setter Property="Foreground" Value="#8b8d93"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#c8aa6e"/>
                                <Setter Property="Foreground" Value="#1a1a2e"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3a3d45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Spell icon toggle -->
        <Style x:Key="SpellIcon" TargetType="ToggleButton">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="IsChecked" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="IconBorder" CornerRadius="3"
                                    BorderBrush="#c8aa6e" BorderThickness="2" ClipToBounds="True">
                                <ContentPresenter/>
                            </Border>
                            <Border x:Name="DimOverlay" CornerRadius="3" Background="#99000000"
                                    Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="IconBorder" Property="BorderBrush" Value="#333"/>
                                <Setter TargetName="DimOverlay" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="IconBorder" Property="BorderBrush" Value="#e0c080"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slider -->
        <Style x:Key="GoldSlider" TargetType="Slider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="TickFrequency" Value="5"/>
            <Setter Property="Width" Value="140"/>
        </Style>
    </Window.Resources>

    <Canvas>
        <!-- Main compact button -->
        <Border x:Name="MainButton" Background="#E5111319" CornerRadius="6" BorderBrush="#2a2d35" BorderThickness="1"
                Padding="10,5" Cursor="Hand"
                MouseLeftButtonDown="MainButton_Click" MouseMove="MainButton_MouseMove" MouseLeftButtonUp="MainButton_MouseUp">
            <DockPanel>
                <TextBlock Text="WowBot" FontSize="12" FontWeight="Bold" Foreground="#c8aa6e"/>
                <TextBlock x:Name="TxtSpec" Text="" FontSize="9" Foreground="#5a5d65"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
            </DockPanel>
        </Border>

        <!-- Main menu (sections list) -->
        <Border x:Name="MenuPanel" Visibility="Collapsed" Canvas.Top="30"
                Background="#E5111319" CornerRadius="6" BorderBrush="#2a2d35" BorderThickness="1"
                Padding="2">
            <StackPanel Width="160">
                <Border Style="{StaticResource MenuItem}" MouseLeftButtonDown="MenuRotation_Click">
                    <DockPanel>
                        <TextBlock Text="Ротация" Foreground="#c8aa6e" FontSize="11" FontWeight="SemiBold"/>
                        <ToggleButton x:Name="BtnRotation" Style="{StaticResource ToggleBtn}" Content="OFF"
                                      DockPanel.Dock="Right" Click="BtnRotation_Click" Width="34"/>
                        <TextBlock Text="&#x25B6;" Foreground="#5a5d65" FontSize="9" DockPanel.Dock="Right"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                    </DockPanel>
                </Border>
                <Border Style="{StaticResource MenuItem}" MouseLeftButtonDown="MenuAoe_Click">
                    <DockPanel>
                        <TextBlock Text="AoE" Foreground="#c8aa6e" FontSize="11" FontWeight="SemiBold"/>
                        <ToggleButton x:Name="BtnAoe" Style="{StaticResource ToggleBtn}" Content="OFF"
                                      DockPanel.Dock="Right" Click="BtnAoe_Click" Width="34"/>
                        <TextBlock Text="&#x25B6;" Foreground="#5a5d65" FontSize="9" DockPanel.Dock="Right"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                    </DockPanel>
                </Border>
                <Border Style="{StaticResource MenuItem}" MouseLeftButtonDown="MenuBuffs_Click">
                    <DockPanel>
                        <TextBlock Text="Баффы" Foreground="#c8aa6e" FontSize="11" FontWeight="SemiBold"/>
                        <ToggleButton x:Name="BtnBuffs" Style="{StaticResource ToggleBtn}" Content="OFF"
                                      DockPanel.Dock="Right" Click="BtnBuffs_Click" Width="34"/>
                        <TextBlock Text="&#x25B6;" Foreground="#5a5d65" FontSize="9" DockPanel.Dock="Right"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                    </DockPanel>
                </Border>
                <Border Style="{StaticResource MenuItem}" MouseLeftButtonDown="MenuFollow_Click">
                    <DockPanel>
                        <TextBlock Text="Следование" Foreground="#c8aa6e" FontSize="11" FontWeight="SemiBold"/>
                        <ToggleButton x:Name="BtnFollow" Style="{StaticResource ToggleBtn}" Content="OFF"
                                      DockPanel.Dock="Right" Click="BtnFollow_Click" Width="34"/>
                        <TextBlock Text="&#x25B6;" Foreground="#5a5d65" FontSize="9" DockPanel.Dock="Right"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                    </DockPanel>
                </Border>
                <Border Style="{StaticResource MenuItem}" MouseLeftButtonDown="MenuTarget_Click">
                    <DockPanel>
                        <TextBlock Text="Таргет" Foreground="#c8aa6e" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Text="&#x25B6;" Foreground="#5a5d65" FontSize="9" DockPanel.Dock="Right"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                    </DockPanel>
                </Border>

                <Border Style="{StaticResource MenuItem}" MouseLeftButtonDown="MenuHivemind_Click">
                    <DockPanel>
                        <TextBlock Text="Hivemind" Foreground="#c8aa6e" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Text="&#x25B6;" Foreground="#5a5d65" FontSize="9" DockPanel.Dock="Right"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                    </DockPanel>
                </Border>

                <!-- Info -->
                <Border Background="#16181e" Padding="8,4" Margin="0,2,0,0" CornerRadius="3">
                    <StackPanel>
                        <TextBlock x:Name="TxtInfo" Text="" Foreground="#5a5d65" FontSize="9" FontFamily="Consolas"/>
                        <TextBlock x:Name="TxtFollowInfo" Text="" Foreground="#5a5d65" FontSize="9" FontFamily="Consolas"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Submenu panel (appears to the right) -->
        <Border x:Name="SubPanel" Visibility="Collapsed" Canvas.Top="30" Canvas.Left="168"
                Background="#E5111319" CornerRadius="6" BorderBrush="#2a2d35" BorderThickness="1"
                Padding="8,6">
            <StackPanel x:Name="SubContent" Width="200"/>
        </Border>
    </Canvas>
</Window>
