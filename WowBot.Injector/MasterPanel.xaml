<Window x:Class="WowBot.Injector.MasterPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Master" Width="260" SizeToContent="Height"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="10" Background="#CC0a0a0f" BorderBrush="#40C8A84E" BorderThickness="1" Padding="8">
        <Grid>
        <StackPanel>
            <!-- Header -->
            <Grid Margin="0,0,0,6">
                <TextBlock Text="Master" FontSize="11" FontWeight="Bold"
                           Foreground="#C8A84E" VerticalAlignment="Center"/>
                <Button Content="⚙" FontSize="11" Foreground="#555" HorizontalAlignment="Right"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Click="BtnSettings_BtnClick" ToolTip="Горячие клавиши"/>
            </Grid>

            <!-- Buttons -->
            <UniformGrid Columns="3" Margin="0,0,0,2">
                <Button x:Name="BtnAttack" Content="⚔" FontSize="18" ToolTip="Бейте таргет"
                        Click="BtnAttack_Click" Style="{x:Null}"
                        Background="#1a1a28" Foreground="#e8e6e3" BorderThickness="0"
                        Height="40" Margin="1" Cursor="Hand"/>
                <Button x:Name="BtnFollow" Content="🏃" FontSize="18" ToolTip="Ко мне"
                        Click="BtnFollow_Click" Style="{x:Null}"
                        Background="#1a1a28" Foreground="#e8e6e3" BorderThickness="0"
                        Height="40" Margin="1" Cursor="Hand"/>
                <Button x:Name="BtnStop" Content="⏹" FontSize="18" ToolTip="Стоп"
                        Click="BtnStop_Click" Style="{x:Null}"
                        Background="#1a1a28" Foreground="#e8e6e3" BorderThickness="0"
                        Height="40" Margin="1" Cursor="Hand"/>
            </UniformGrid>

            <!-- Авто кнопка -->
            <Button x:Name="BtnAuto" Content="Авто" FontSize="10"
                    Click="BtnAuto_Click" Style="{x:Null}"
                    Background="#1a1a28" Foreground="#C8A84E" BorderThickness="0"
                    Height="24" Margin="1,2,1,2" Cursor="Hand" ToolTip="Follow + авто-ассист в бою"/>

            <!-- AutoPve toggle -->
            <Button x:Name="BtnAutoPve" Content="⚔ Автопве" FontSize="10"
                    Click="BtnAutoPve_Click" Style="{x:Null}"
                    Background="#1a1a28" Foreground="#888" BorderThickness="0"
                    Height="24" Margin="1,0,1,2" Cursor="Hand" ToolTip="Авто-тактики на боссах (ЦЛК)"/>

            <!-- Slave panel -->
            <StackPanel x:Name="SlavePanel" Margin="0,4,0,0"/>

            <!-- Hotkey labels -->
            <UniformGrid Columns="3">
                <TextBlock x:Name="TxtHkAttack" Text="" FontSize="9" Foreground="#555"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtHkFollow" Text="" FontSize="9" Foreground="#555"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtHkStop" Text="" FontSize="9" Foreground="#555"
                           HorizontalAlignment="Center"/>
            </UniformGrid>

            <!-- Hotkey settings (hidden by default) -->
            <Border x:Name="HotkeyPanel" Visibility="Collapsed" Margin="0,6,0,0"
                    Background="#12121a" CornerRadius="6" Padding="8">
                <StackPanel>
                    <TextBlock Text="Горячие клавиши" FontSize="10" Foreground="#C8A84E" Margin="0,0,0,4"/>
                    <Grid Margin="0,2,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Атака:" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                        <Button x:Name="BtnSetHkAttack" Grid.Column="1" Content="Нажми..."
                                FontSize="10" Background="#1a1a28" Foreground="#e8e6e3"
                                BorderThickness="1" BorderBrush="#333" Cursor="Hand" Height="24"
                                Click="BtnSetHotkey_Click" Tag="attack"/>
                    </Grid>
                    <Grid Margin="0,2,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Ко мне:" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                        <Button x:Name="BtnSetHkFollow" Grid.Column="1" Content="Нажми..."
                                FontSize="10" Background="#1a1a28" Foreground="#e8e6e3"
                                BorderThickness="1" BorderBrush="#333" Cursor="Hand" Height="24"
                                Click="BtnSetHotkey_Click" Tag="follow"/>
                    </Grid>
                    <Grid Margin="0,2,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Стоп:" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                        <Button x:Name="BtnSetHkStop" Grid.Column="1" Content="Нажми..."
                                FontSize="10" Background="#1a1a28" Foreground="#e8e6e3"
                                BorderThickness="1" BorderBrush="#333" Cursor="Hand" Height="24"
                                Click="BtnSetHotkey_Click" Tag="stop"/>
                    </Grid>
                    <Button Content="Сбросить" FontSize="9" Background="#2d1515" Foreground="#aaa"
                            BorderThickness="0" Cursor="Hand" Height="20" Margin="0,4,0,0"
                            Click="BtnClearHotkeys_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
        </Grid>
    </Border>
</Window>
