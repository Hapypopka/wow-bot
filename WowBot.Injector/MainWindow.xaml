<Window x:Class="WowBot.Injector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WowBot" Height="420" Width="380"
        Icon="app.ico"
        WindowStartupLocation="CenterScreen"
        Background="#0a0a0f" ResizeMode="CanMinimize"
        WindowStyle="None" AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        SizeToContent="Height">

    <Window.Resources>
        <!-- Accent colors -->
        <Color x:Key="GoldColor">#C8A84E</Color>
        <Color x:Key="GoldDim">#8B7331</Color>
        <Color x:Key="GoldGlow">#FFD966</Color>
        <Color x:Key="CardBg">#12121a</Color>
        <Color x:Key="CardBorder">#1e1e2e</Color>
        <Color x:Key="TextPrimary">#e8e6e3</Color>
        <Color x:Key="TextSecondary">#6b6b7b</Color>
        <Color x:Key="RedAccent">#c0392b</Color>
        <Color x:Key="GreenAccent">#27ae60</Color>

        <SolidColorBrush x:Key="GoldBrush" Color="{StaticResource GoldColor}"/>
        <SolidColorBrush x:Key="GoldDimBrush" Color="{StaticResource GoldDim}"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBg}"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorder}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>

        <!-- Primary button (gold) -->
        <Style x:Key="GoldButton" TargetType="Button">
            <Setter Property="Foreground" Value="#0a0a0f"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6" Padding="20,10"
                                Background="{StaticResource GoldBrush}"
                                BorderThickness="0">
                            <Border.Effect>
                                <DropShadowEffect Color="{StaticResource GoldGlow}" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource GoldGlow}"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button (outline) -->
        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="5" Padding="14,7"
                                Background="Transparent"
                                BorderBrush="{StaticResource GoldDimBrush}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#1a1a28"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger button (red) -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Foreground" Value="#e8e6e3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="5" Padding="12,6"
                                Background="#1a0a0a" BorderBrush="#3d1515" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#2d1010"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main border with subtle gold outline -->
    <Border CornerRadius="12" BorderBrush="#1a1a28" BorderThickness="1"
            Background="#0a0a0f">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0" Padding="16,12">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="app.ico" Width="28" Height="28" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="WowBot" FontSize="18" FontWeight="Bold" Foreground="{StaticResource GoldBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="WoTLK 3.3.5a" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="8,3,0,0"/>
                    </StackPanel>
                    <!-- Close button -->
                    <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Foreground="{StaticResource TextSecondaryBrush}" Background="Transparent"
                            BorderThickness="0" Cursor="Hand" Padding="6,2"
                            Click="BtnClose_Click"/>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="20,0,20,20">

                <!-- Status indicator -->
                <Border x:Name="StatusCard" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                        Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <!-- Not connected state -->
                        <StackPanel x:Name="PanelDisconnected" Grid.Row="0" HorizontalAlignment="Center">
                            <Ellipse Width="10" Height="10" Fill="#c0392b" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#c0392b" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="Не подключено" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtStatus" Text="Запусти WoW и нажми Подключить"
                                       Foreground="#4a4a5a" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Connected state (hidden by default) -->
                        <StackPanel x:Name="PanelConnected" Grid.Row="0" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                                <Ellipse Width="10" Height="10" Fill="#27ae60" Margin="0,0,8,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#27ae60" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock x:Name="TxtCharName" Text="Lovelion" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtSpecName" Text="Balance Druid" FontSize="12"
                                       Foreground="{StaticResource GoldBrush}" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                            <TextBlock x:Name="TxtPidInfo" Text="PID: 1234" FontSize="10"
                                       Foreground="#3a3a4a" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Connect / Disconnect buttons -->
                <Grid Margin="0,0,0,16">
                    <Button x:Name="BtnAttach" Content="Подключить" Style="{StaticResource GoldButton}"
                            Click="BtnAttach_Click" HorizontalAlignment="Stretch"/>
                    <Button x:Name="BtnDetach" Content="Отключить" Style="{StaticResource DangerButton}"
                            Click="BtnDetach_Click" Visibility="Collapsed" HorizontalAlignment="Stretch"/>
                </Grid>

                <!-- Multibox panel -->
                <Border x:Name="MultiboxPanel" CornerRadius="8" Margin="0,0,0,12"
                        Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <Button Click="MultiboxHeader_Click" Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="12,10" HorizontalContentAlignment="Left">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="MultiboxArrow" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{StaticResource GoldDimBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Мультибокс" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <StackPanel x:Name="MultiboxContent" Visibility="Collapsed" Margin="12,0,12,12">
                            <Button Content="🔍 Сканировать WoW" Style="{StaticResource OutlineButton}"
                                    Click="BtnScanWow_Click" Margin="0,0,0,8" HorizontalAlignment="Stretch"/>
                            <StackPanel x:Name="WowProcessList"/>
                            <Button x:Name="BtnLaunchAll" Content="🚀 Запустить всех" Style="{StaticResource GoldButton}"
                                    Click="BtnLaunchAll_Click" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                    Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Lua Console (collapsed by default) -->
                <Border CornerRadius="8" Margin="0,0,0,12"
                        Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <!-- Header — clickable to expand -->
                        <Button Click="LuaHeader_BtnClick" Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="12,10" HorizontalContentAlignment="Left">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="LuaArrow" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{StaticResource GoldDimBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Lua Console" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <!-- Content — hidden by default -->
                        <StackPanel x:Name="LuaContent" Visibility="Collapsed" Margin="12,0,12,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtLua" Grid.Column="0" Background="#08080e" Foreground="#4ade80"
                                         BorderThickness="1" BorderBrush="#1e1e2e" Padding="10,8"
                                         FontFamily="Consolas" FontSize="12" CaretBrush="#4ade80"
                                         Text="CastSpellByName('Fireball')"
                                         KeyDown="TxtLua_KeyDown"
                                         VerticalContentAlignment="Center"/>
                                <Button x:Name="BtnExecuteLua" Grid.Column="1" Content="Run" Style="{StaticResource OutlineButton}"
                                        Click="BtnExecuteLua_Click" IsEnabled="False" Margin="8,0,0,0"/>
                            </Grid>
                            <TextBlock x:Name="TxtLuaStatus" Text="" Foreground="#4a4a5a" FontSize="10" Margin="0,6,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Hidden elements for compatibility -->
                <TextBlock x:Name="TxtName" Visibility="Collapsed"/>
                <TextBlock x:Name="TxtHealth" Visibility="Collapsed"/>
                <TextBlock x:Name="TxtMana" Visibility="Collapsed"/>
                <TextBlock x:Name="TxtLevel" Visibility="Collapsed"/>
                <TextBlock x:Name="TxtPosition" Visibility="Collapsed"/>
                <TextBlock x:Name="TxtTarget" Visibility="Collapsed"/>
                <TextBlock x:Name="TxtObjectCount" Visibility="Collapsed"/>
                <TextBlock x:Name="TxtRotationStatus" Visibility="Collapsed"/>
                <ListBox x:Name="LstObjects" Visibility="Collapsed"/>

                <!-- Footer -->
                <TextBlock x:Name="TxtFooter" Text="v1.30" Foreground="#2a2a3a" FontSize="10"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
