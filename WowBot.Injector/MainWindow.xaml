<Window x:Class="WowBot.Injector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WowBot — WoTLK 3.3.5a" Height="780" Width="520"
        Icon="app.ico"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e" ResizeMode="CanMinimize">

    <Window.Resources>
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#0f3460"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0f3460"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="#1a4a2e"/>
            <Setter Property="BorderBrush" Value="#2d7a4a"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#b0b0b0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e94560"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="WowBot" FontSize="24" FontWeight="Bold"
                   Foreground="#e94560" Margin="0,0,0,12"/>

        <!-- Connection -->
        <Border Grid.Row="1" Background="#16213e" CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="PROCESS" Foreground="#0f3460" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnAttach" Content="Attach + Hook" Style="{StaticResource DarkButton}"
                            Click="BtnAttach_Click" Margin="0,0,8,0"/>
                    <Button x:Name="BtnDetach" Content="Detach" Style="{StaticResource DarkButton}"
                            Click="BtnDetach_Click" IsEnabled="False"/>
                    <Button x:Name="BtnDump" Content="Dump" Style="{StaticResource DarkButton}"
                            Click="BtnDump_Click" IsEnabled="False" Margin="8,0,0,0"/>
                    <Button x:Name="BtnScanSpells" Content="Scan Spells" Style="{StaticResource DarkButton}"
                            Click="BtnScanSpells_Click" IsEnabled="False" Margin="8,0,0,0"/>
                </StackPanel>
                <TextBlock x:Name="TxtStatus" Text="Not connected" Style="{StaticResource LabelStyle}" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Player data -->
        <Border Grid.Row="2" Background="#16213e" CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="CHARACTER" Foreground="#0f3460" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name: " Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtName" Text="-" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="HP: " Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtHealth" Text="-" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Mana: " Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtMana" Text="-" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Level: " Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtLevel" Text="-" Style="{StaticResource ValueStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Position: " Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TxtPosition" Text="-" Style="{StaticResource ValueStyle}" TextWrapping="Wrap"/>
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Target: " Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="TxtTarget" Text="-" Style="{StaticResource ValueStyle}"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Rotation -->
        <Border Grid.Row="3" Background="#16213e" CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="ROTATION" Foreground="#0f3460" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnRotationToggle" Content="Start Rotation" Style="{StaticResource GreenButton}"
                            Click="BtnRotationToggle_Click" IsEnabled="False" Margin="0,0,8,0"/>
                    <Button x:Name="BtnSetFollow" Content="Set Follow" Style="{StaticResource DarkButton}"
                            Click="BtnSetFollow_Click" IsEnabled="False" Margin="0,0,4,0"/>
                    <Button x:Name="BtnClearFollow" Content="Clear" Style="{StaticResource DarkButton}"
                            Click="BtnClearFollow_Click" IsEnabled="False"/>
                </StackPanel>
                <TextBlock x:Name="TxtRotationStatus" Text="Not active" Style="{StaticResource LabelStyle}" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- Lua Console -->
        <Border Grid.Row="4" Background="#16213e" CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="LUA CONSOLE" Foreground="#0f3460" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtLua" Grid.Column="0" Background="#0a0a1a" Foreground="#00ff88"
                             BorderThickness="1" BorderBrush="#0f3460" Padding="8,6"
                             FontFamily="Consolas" FontSize="12"
                             Text="CastSpellByName('Fireball')"
                             KeyDown="TxtLua_KeyDown"/>
                    <Button x:Name="BtnExecuteLua" Grid.Column="1" Content="Run" Style="{StaticResource GreenButton}"
                            Click="BtnExecuteLua_Click" IsEnabled="False" Margin="8,0,0,0"/>
                </Grid>
                <TextBlock x:Name="TxtLuaStatus" Text="Hook not installed" Style="{StaticResource LabelStyle}" Margin="0,6,0,0"/>
                <!-- Quick buttons -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="/say Hello" Style="{StaticResource DarkButton}" FontSize="10" Padding="8,4"
                            Click="BtnQuickLua_Click" Tag="SendChatMessage('Hello from WowBot!', 'SAY')" Margin="0,0,4,0"/>
                    <Button Content="/dance" Style="{StaticResource DarkButton}" FontSize="10" Padding="8,4"
                            Click="BtnQuickLua_Click" Tag="DoEmote('dance')" Margin="0,0,4,0"/>
                    <Button Content="Jump" Style="{StaticResource DarkButton}" FontSize="10" Padding="8,4"
                            Click="BtnQuickLua_Click" Tag="JumpOrAscendStart()" Margin="0,0,4,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Objects list -->
        <Border Grid.Row="5" Background="#16213e" CornerRadius="6" Padding="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" x:Name="TxtObjectCount" Text="OBJECTS (0)"
                           Foreground="#0f3460" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                <ListBox x:Name="LstObjects" Background="#0a0a1a" Foreground="#c0c0c0"
                         BorderThickness="0" FontFamily="Consolas" FontSize="11"/>
            </DockPanel>
        </Border>

        <!-- Footer -->
        <TextBlock Grid.Row="6" x:Name="TxtFooter" Text="WowBot v0.3 | Stage 3: Rotation Engine"
                   Foreground="#444" FontSize="10" Margin="0,8,0,0" HorizontalAlignment="Center"/>
    </Grid>
</Window>
